# Core
APP_NAME=AI Assist Backend
ENV=development
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=replace-with-a-32-byte-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database (switch to Postgres in production)
DATABASE_URL=sqlite:///./backend/app.db
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ai_assist
AUTO_CREATE_DB_SCHEMA=true

# Cache (Redis recommended for production)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Admin bootstrap
INITIAL_ADMIN_EMAIL=admin@aiassist.app
INITIAL_ADMIN_PASSWORD=replace-with-strong-admin-password
INITIAL_ADMIN_NAME=System Admin

# Auth policy
ALLOW_PUBLIC_REGISTRATION=false
RATE_LIMIT_LOGIN_PER_MINUTE=8

# Cache policy
USER_LIST_CACHE_TTL_SECONDS=30
